{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(sed -n *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(dotnet build *)",
      "Bash(dotnet test *)",
      "Bash(dotnet run --project src/backend/Jobs.Api *)",
      "Bash(dotnet run --project src/backend/Jobs.Worker *)",
      "Bash(npm run lint *)",
      "Bash(npm run build *)",
      "Bash(npm run dev *)",
      "Bash(docker compose ps *)"
    ],
    "ask": [
      "Bash(dotnet restore *)",
      "Bash(npm install *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development.local)",
      "Read(./.env.test.local)",
      "Read(./.env.production.local)",
      "Read(./src/backend/.env)",
      "Read(./src/frontend/.env)",
      "Read(./src/frontend/.env.local)",
      "Read(./src/frontend/.env.development.local)",
      "Read(./src/frontend/.env.test.local)",
      "Read(./src/frontend/.env.production.local)",
      "Read(./src/frontend/node_modules/**)",
      "Read(./src/frontend/.next/**)",
      "Read(./src/backend/**/bin/**)",
      "Read(./src/backend/**/obj/**)",
      "Read(./.claude/settings.local.json)",
      "Read(./CLAUDE.local.md)",
      "Read(./secrets/**)"
    ]
  }
}
