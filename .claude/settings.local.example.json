{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "120000"
  },
  "permissions": {
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(dotnet restore *)",
      "Bash(npm install *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)"
    ]
  }
}
