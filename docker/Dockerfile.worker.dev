FROM mcr.microsoft.com/dotnet/sdk:8.0

ENV DOTNET_CLI_TELEMETRY_OPTOUT=true
ENV DOTNET_SKIP_FIRST_TIME_EXPERIENCE=true
ENV DOTNET_USE_POLLING_FILE_WATCHER=true

WORKDIR /workspace

COPY src/backend/Jobs.sln                                     src/backend/Jobs.sln
COPY src/backend/Jobs.Domain/Jobs.Domain.csproj               src/backend/Jobs.Domain/
COPY src/backend/Jobs.Infrastructure/Jobs.Infrastructure.csproj src/backend/Jobs.Infrastructure/
COPY src/backend/Jobs.Api/Jobs.Api.csproj                     src/backend/Jobs.Api/
COPY src/backend/Jobs.Worker/Jobs.Worker.csproj               src/backend/Jobs.Worker/
COPY src/backend/Jobs.Tests/Jobs.Tests.csproj                 src/backend/Jobs.Tests/

RUN dotnet restore src/backend/Jobs.sln

WORKDIR /workspace/src/backend

CMD ["dotnet", "watch", "--non-interactive", "--project", "Jobs.Worker", "run"]
