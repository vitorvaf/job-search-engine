# Optional environment variable overrides for Jobs.Api / Jobs.Worker.
# ASP.NET does not auto-load this file automatically.
# Source it in your shell or copy the keys into your IDE launch profile if you
# want to override appsettings locally.

ConnectionStrings__JobsDb=Host=localhost;Port=5432;Database=jobs;Username=jobs;Password=jobs
Meilisearch__BaseUrl=http://localhost:7700
Meilisearch__MasterKey=dev_master_key_change_me
App__SearchIndexName=jobs

# Internal API auth between Next.js BFF and Jobs.Api.
App__Auth__BffInternalApiKey=dev_internal_key_change_me
App__Auth__Tokens__EmailVerificationMinutes=1440
App__Auth__Tokens__PasswordResetMinutes=30

# Public URLs used in account email links.
App__PublicUrls__FrontendBaseUrl=http://localhost:3000

# Email sender configuration (Mailpit defaults for local dev).
App__Email__FromName=Jobs
App__Email__FromAddress=no-reply@job-search.local
App__Email__Smtp__Host=localhost
App__Email__Smtp__Port=1025
App__Email__Smtp__UseSsl=false
# App__Email__Smtp__Username=
# App__Email__Smtp__Password=
