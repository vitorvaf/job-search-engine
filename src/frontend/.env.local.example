# Used only by the Next.js server-side BFF route handlers.
BACKEND_URL=http://localhost:5004
BACKEND_INTERNAL_API_KEY=dev_internal_key_change_me

# Auth.js
AUTH_SECRET=replace-with-long-random-secret
# Optional compatibility alias for libraries expecting NEXTAUTH_SECRET.
NEXTAUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional absolute site URL for SSR environments behind proxies.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
